    {
      "name": "6 — Notificaciones",
      "item": [
        {
          "name": "Enviar Notificación",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN_EMPRESA}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"destinatarioId\": \"{{ID_TALENTO}}\",\n  \"tipo\": \"APROBADO\",\n  \"mensaje\": \"¡Felicitaciones! Tu postulación al reto fue aprobada.\"\n}" },
            "url": { "raw": "{{BASE_NOTIFICACIONES}}/api/v1/notificaciones", "host": ["{{BASE_NOTIFICACIONES}}"], "path": ["api","v1","notificaciones"] }
          }
        },
        {
          "name": "Ver Mis Notificaciones",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN_TALENTO}}" }],
            "url": { "raw": "{{BASE_NOTIFICACIONES}}/api/v1/notificaciones", "host": ["{{BASE_NOTIFICACIONES}}"], "path": ["api","v1","notificaciones"] }
          }
        },
        {
          "name": "Ver Notificaciones No Leídas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN_TALENTO}}" }],
            "url": { "raw": "{{BASE_NOTIFICACIONES}}/api/v1/notificaciones?leida=false", "host": ["{{BASE_NOTIFICACIONES}}"], "path": ["api","v1","notificaciones"], "query": [{ "key": "leida", "value": "false" }] }
          }
        },
        {
          "name": "Marcar Notificación como Leída",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN_TALENTO}}" }],
            "url": { "raw": "{{BASE_NOTIFICACIONES}}/api/v1/notificaciones/:id/leida", "host": ["{{BASE_NOTIFICACIONES}}"], "path": ["api","v1","notificaciones",":id","leida"], "variable": [{ "key": "id", "value": "{{NOTIFICACION_ID}}" }] }
          }
        }
      ]
