            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN_EMPRESA}}" }],
            "url": { "raw": "{{BASE_POSTULACIONES}}/api/v1/postulaciones/reto/{{RETO_ID}}", "host": ["{{BASE_POSTULACIONES}}"], "path": ["api","v1","postulaciones","reto","{{RETO_ID}}"] }
          }
        },
        {
          "name": "Historial del Talento",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN_TALENTO}}" }],
            "url": { "raw": "{{BASE_POSTULACIONES}}/api/v1/postulaciones/talento/{{ID_TALENTO}}", "host": ["{{BASE_POSTULACIONES}}"], "path": ["api","v1","postulaciones","talento","{{ID_TALENTO}}"] }
          }
        },
        {
          "name": "Evaluar Postulación (APROBADO)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
