{
  "info": {
    "name": "Somos Ayni — Microservicios",
    "description": "Colección completa para probar los 8 microservicios de Somos Ayni. Flujo de negocio: Registro → Perfiles → Retos → Postulaciones → Evaluación → Insignias → Notificaciones → Métricas → Asistente IA",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_IDENTIDAD", "value": "http://localhost:8081" },
    { "key": "BASE_PERFILES", "value": "http://localhost:8082" },
    { "key": "BASE_RETOS", "value": "http://localhost:8083" },
    { "key": "BASE_POSTULACIONES", "value": "http://localhost:8084" },
    { "key": "BASE_HABILIDADES", "value": "http://localhost:8085" },
    { "key": "BASE_NOTIFICACIONES", "value": "http://localhost:8086" },
    { "key": "BASE_METRICAS", "value": "http://localhost:8087" },
    { "key": "BASE_ASISTENTE", "value": "http://localhost:8088" },
    { "key": "TOKEN_EMPRESA", "value": "" },
    { "key": "TOKEN_TALENTO", "value": "" },
    { "key": "ID_EMPRESA", "value": "" },
    { "key": "ID_TALENTO", "value": "" },
    { "key": "RETO_ID", "value": "" },
    { "key": "POSTULACION_ID", "value": "" }
  ],
  "item": [
    {
      "name": "1 — Identidad (Auth)",
      "item": [
        {
          "name": "Registro Empresa",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "pm.collectionVariables.set('TOKEN_EMPRESA', res.token);",
            "pm.collectionVariables.set('ID_EMPRESA', res.usuarioId);",
            "pm.test('Registro empresa OK', () => pm.response.to.have.status(201));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"empresa@somosayni.com\",\n  \"password\": \"Pass1234!\",\n  \"rol\": \"EMPRESA\"\n}" },
            "url": { "raw": "{{BASE_IDENTIDAD}}/api/v1/auth/registro", "host": ["{{BASE_IDENTIDAD}}"], "path": ["api","v1","auth","registro"] }
          }
        },
        {
          "name": "Registro Talento",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "pm.collectionVariables.set('TOKEN_TALENTO', res.token);",
            "pm.collectionVariables.set('ID_TALENTO', res.usuarioId);",
            "pm.test('Registro talento OK', () => pm.response.to.have.status(201));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"talento@somosayni.com\",\n  \"password\": \"Pass1234!\",\n  \"rol\": \"TALENTO\"\n}" },
            "url": { "raw": "{{BASE_IDENTIDAD}}/api/v1/auth/registro", "host": ["{{BASE_IDENTIDAD}}"], "path": ["api","v1","auth","registro"] }
          }
        },
        {
          "name": "Login Empresa",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "pm.collectionVariables.set('TOKEN_EMPRESA', res.token);",
            "pm.test('Login OK', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"empresa@somosayni.com\",\n  \"password\": \"Pass1234!\"\n}" },
            "url": { "raw": "{{BASE_IDENTIDAD}}/api/v1/auth/login", "host": ["{{BASE_IDENTIDAD}}"], "path": ["api","v1","auth","login"] }
          }
        },
        {
          "name": "Login Talento",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "pm.collectionVariables.set('TOKEN_TALENTO', res.token);",
            "pm.test('Login OK', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"talento@somosayni.com\",\n  \"password\": \"Pass1234!\"\n}" },
            "url": { "raw": "{{BASE_IDENTIDAD}}/api/v1/auth/login", "host": ["{{BASE_IDENTIDAD}}"], "path": ["api","v1","auth","login"] }
          }
        },
        {
          "name": "Cambiar Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN_EMPRESA}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"passwordActual\": \"Pass1234!\",\n  \"nuevaPassword\": \"NuevaPass456!\"\n}" },
            "url": { "raw": "{{BASE_IDENTIDAD}}/api/v1/auth/cambiar-password", "host": ["{{BASE_IDENTIDAD}}"], "path": ["api","v1","auth","cambiar-password"] }
          }
        }
      ]
    },
    {
      "name": "2 — Perfiles",
      "item": [
        {
          "name": "Crear Perfil Empresa",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN_EMPRESA}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"razonSocial\": \"Tech Perú SAC\",\n  \"ruc\": \"20123456789\",\n  \"sector\": \"Tecnología\"\n}" },
            "url": { "raw": "{{BASE_PERFILES}}/api/v1/perfiles/empresa", "host": ["{{BASE_PERFILES}}"], "path": ["api","v1","perfiles","empresa"] }
          }
        },
        {
          "name": "Crear Perfil Talento",
          "request": {
            "method": "POST",
