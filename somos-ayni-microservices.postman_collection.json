          }
        },
        {
          "name": "Evaluar Postulación (RECHAZADO)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN_EMPRESA}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"puntuacion\": 45,\n  \"feedback\": \"Falta documentación y pruebas unitarias\",\n  \"resultado\": \"RECHAZADO\"\n}" },
            "url": { "raw": "{{BASE_POSTULACIONES}}/api/v1/postulaciones/{{POSTULACION_ID}}/evaluar", "host": ["{{BASE_POSTULACIONES}}"], "path": ["api","v1","postulaciones","{{POSTULACION_ID}}","evaluar"] }
          }
        }
      ]
