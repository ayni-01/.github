            "url": { "raw": "{{BASE_PERFILES}}/api/v1/perfiles/talento", "host": ["{{BASE_PERFILES}}"], "path": ["api","v1","perfiles","talento"] }
          }
        },
        {
          "name": "Obtener Perfil Empresa",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN_EMPRESA}}" }],
            "url": { "raw": "{{BASE_PERFILES}}/api/v1/perfiles/empresa/{{ID_EMPRESA}}", "host": ["{{BASE_PERFILES}}"], "path": ["api","v1","perfiles","empresa","{{ID_EMPRESA}}"] }
          }
        },
        {
          "name": "Obtener Perfil Talento",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN_TALENTO}}" }],
            "url": { "raw": "{{BASE_PERFILES}}/api/v1/perfiles/talento/{{ID_TALENTO}}", "host": ["{{BASE_PERFILES}}"], "path": ["api","v1","perfiles","talento","{{ID_TALENTO}}"] }
          }
        },
        {
          "name": "Editar Perfil Talento",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN_TALENTO}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"nombreCompleto\": \"Juan Pérez García\",\n  \"ubicacion\": \"Lima, Perú\",\n  \"sobreMi\": \"Desarrollador backend con experiencia en Java y Spring Boot\"\n}" },
            "url": { "raw": "{{BASE_PERFILES}}/api/v1/perfiles/talento/{{ID_TALENTO}}", "host": ["{{BASE_PERFILES}}"], "path": ["api","v1","perfiles","talento","{{ID_TALENTO}}"] }
          }
        }
      ]
    },
    {
      "name": "3 — Retos",
      "item": [
        {
          "name": "Publicar Reto",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "pm.collectionVariables.set('RETO_ID', res.id);",
            "pm.test('Reto creado', () => pm.response.to.have.status(201));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN_EMPRESA}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"titulo\": \"Desarrollar API REST con Spring Boot\",\n  \"descripcion\": \"Crear una API RESTful completa con autenticación JWT, documentación Swagger y pruebas unitarias\",\n  \"empresaId\": \"{{ID_EMPRESA}}\",\n  \"modalidad\": \"REMOTO\",\n  \"duracionDias\": 30\n}" },
            "url": { "raw": "{{BASE_RETOS}}/api/v1/retos", "host": ["{{BASE_RETOS}}"], "path": ["api","v1","retos"] }
          }
        },
        {
          "name": "Listar Retos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN_TALENTO}}" }],
            "url": { "raw": "{{BASE_RETOS}}/api/v1/retos", "host": ["{{BASE_RETOS}}"], "path": ["api","v1","retos"] }
          }
        },
        {
          "name": "Cerrar Reto",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN_EMPRESA}}" }],
            "url": { "raw": "{{BASE_RETOS}}/api/v1/retos/{{RETO_ID}}/cerrar", "host": ["{{BASE_RETOS}}"], "path": ["api","v1","retos","{{RETO_ID}}","cerrar"] }
          }
        },
        {
          "name": "Duplicar Reto",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN_EMPRESA}}" }],
            "url": { "raw": "{{BASE_RETOS}}/api/v1/retos/{{RETO_ID}}/duplicar", "host": ["{{BASE_RETOS}}"], "path": ["api","v1","retos","{{RETO_ID}}","duplicar"] }
          }
        }
      ]
    },
    {
      "name": "4 — Postulaciones",
      "item": [
        {
          "name": "Postular a Reto",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "pm.collectionVariables.set('POSTULACION_ID', res.id);",
            "pm.test('Postulación creada', () => pm.response.to.have.status(201));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN_TALENTO}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"retoId\": \"{{RETO_ID}}\",\n  \"urlSolucion\": \"https://github.com/juanperez/api-rest-solution\"\n}" },
            "url": { "raw": "{{BASE_POSTULACIONES}}/api/v1/postulaciones", "host": ["{{BASE_POSTULACIONES}}"], "path": ["api","v1","postulaciones"] }
          }
        },
        {
          "name": "Ver Postulaciones del Reto",
          "request": {
